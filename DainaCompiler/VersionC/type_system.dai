@@
   - checkForCircularDependancies *([SourcePosition] dependancyOrigin, [DainaClass] class, [List<[SourcePosition]>] currentPathList, [Index<[DainaClass]>] currentPathIndex, [Index<[DainaClass]>] visited) {
      [Maybe<[String]>] maybeClassName = \[Maybe<[String]>]:if *([[String]->] find) {
         \class:isEntryPointOrRegularClass *{} *([DainaClassIdentifier] classId, [] _, [] __, [] ___, [] ____) {
            \find \classId:content;
         };
      };
      [String] className = \maybeClassName:isOrElse (*([?]a)->a) (*->\[String]:as ####);
      [Maybe<[DainaClass]>] inCurrentPath = \currentPathIndex:get className;
      \inCurrentPath:isOrElse *{
         \addErrorDependancyRecursion dependancyOrigin currentPathList;
      } *{
         [Maybe<[DainaClass]>] inVisited = \visited:get className;
         \inVisited:isOrElse *{} *{
            \visited:set className \[Maybe<[?]>]:as class;
            \currentPathIndex:set className \[Maybe<[?]>]:as class;
            \currentPathList:append dependancyOrigin;
            [DainaDependancyStructure] dependancyStructure = \class:dependancyStructure;
            \dependancyStructure:iterateDependancies *([DainaClassIdentifier] dependancyID) {
               [Maybe<[DainaClass]>] maybeDependancy = \.classIndex:get \dependancyID:content;
               \maybeDependancy:isOrElse *([DainaClass] dependancy) {
                  \:checkForCircularDependancies (\dependancyID:position) dependancy currentPathList currentPathIndex visited;
               } *{
                  \:addError (\[Error]:missingClass (\class:position));
               };
            };
            \currentPathIndex:set className \[Maybe<[?]>]:nothing;
            [] _ = \currentPathList:removeLast;
         };
      };
   } !{
         [[List<[DainaClass]>]->] addErrorDependancyRecursion = *([SourcePosition] dependancyOrigin, [List<[SourcePosition]>] pathList) {
            [List<[?]>] circularDependanciesPath = \[List<[?]>]:as pathList;
            \circularDependanciesPath:append dependancyOrigin;
            \:addError \[Error]:foundDependancyRecursion circularDependanciesPath;
         };
      }@@

   - orderClassesBasedOnDependancies *([List<[DainaClass]>] classes) -> [Maybe<[List<[DainaClass]>]>] {
      [[DainaClass]->[String]] getClassName = *([DainaClass] class) -> [String] {
         [Variable<[String]>] varClassName = \[Variable<[?]>]:as \[String]:as ####;
         \class:isEntryPointOrRegularClass *{} *([DainaClassIdentifier] classId, [] _, [] __, [] ___, [] ____) {
            \varClassName:set \classId:content;
         };
      } -> \varClassName:get;
      [Index<[DainaClass]>] remaining = \[Index<[DainaClass]>]:empty;
      \classes:iterate *([DainaClass] class) {
         \remaining:set (\getClassName class) \[Maybe<[?]>]:as class;
      };
      [List<[DainaClass]>] classOrder = \[List<[DainaClass]>]:empty;
   } -> \[Loops]:until *([[Maybe<[List<[DainaClass]>]>]->] finish) {
         [List<[DainaClass]>] toAddToOrder = \[List<[DainaClass]>]:empty;
         [Variable<[Boolean]>] varSomeRemaining = \[Variable<[Boolean]>]:as \[Boolean]:false;
         \remaining:iterate *([DainaClass] class) {
            \varSomeRemaining:set \[Boolean]:true;
            [DainaDependancyStructure] dependancyStructure = \class:dependancyStructure;
            [Index<[DainaClassIdentifier]>] dependancies = \dependancyStructure:dependancies;
            [Variable<[Boolean]>] allDependanciesSatisfied = \[Variable<[Boolean]>]:as \[Boolean]:true;
            \dependancies:iterate *([DainaClassIdentifier] dependancy) {
               [Maybe<[?]>] inRemaining = \remaining:get \dependancy:content;
               \inRemaining:isOrElse *{\allDependanciesSatisfied:set \[Boolean]:false} *{};
            };
            [Boolean] addToOrder = \allDependanciesSatisfied:get;
            \addToOrder:ifOrElse *{\toAddToOrder:append class} *{};
         };
         [Boolean] someRemaining = \varSomeRemaining:get;
         \someRemaining:ifOrElse *{
            \toAddToOrder:iterate *([DainaClass] toAdd) {
               \remaining:set (\getClassName toAdd) \[Maybe<[DainaClass]>]:nothing;
               \classOrder:append toAdd;
            };
            [Boolean] loopedDependanciesDetected = \0:isEqualTo \toAddToOrder:length;
            \loopedDependanciesDetected:ifOrElse *{
               [List<[SourcePosition]>] involvedDependancies = \[List<[SourcePosition]>]:empty;
               \remaining:iterate *([DainaClass] involvedDependancy) {
                  \involvedDependancies:append \involvedDependancy:position
               };
               \:addError \[Error]:foundDependancyRecursion involvedDependancies;
               \finish \[Maybe<[?]>]:nothing;
            } *{};
         } *{
            \finish \[Maybe<[?]>]:as classOrder;
         };
      } !{[Natural] 0 = \[Natural]:as ##0##}



   ++ analyze *([List<[DainaClass]>] classes) {
      [Index<[DainaClass]>] visited = \[Index<[DainaClass]>]:empty;
      \classes:iterate *([DainaClass] class) {
         \class:isEntryPointOrRegularClass *([DainaDependancyStructure] dependancyStructure, [DainaExpression] entryPointMethod) {
            [Maybe<[DainaClass]>] entryPoint = \.entryPoint:get;
            \entryPoint:isOrElse 
               *([DainaClass] original){\:addError (\[Error]:duplicateEntryPointClass (\class:position) (\original:position))} 
               *{\.entryPoint:set \[Maybe<[DainaClass]>]:as class};
         } *([DainaClassIdentifier] classId, [List<[DainaType]>] inheritedParentTypes, [Index<[DainaObjectDeclaration]>] instanceObjects, [List<[DainaClassMethod<[DainaExpression]>]>] classMethods, [List<[DainaCompilerInjection]>] compilerInjections) {
            [String] className = \classId:content;
            [Maybe<[?]>] existingClass = \.classIndex:get className;
            \existingClass:isOrElse
               *([DainaClass] original){\:addError (\[Error]:duplicateClassName (\class:position) (\original:position))} 
               *{
                  \.classIndex:set className \[Maybe<[?]>]:as class;
                  [Index<[?]>] classMethodsIndex = \[Index<[List<[DainaClassMethod<[DainaExpression]>]>]>]:empty;
                  \classMethods:iterate *([DainaClassMethod<[DainaExpression]>] classMethod) {
                     [DainaGeneralIdentifier] methodIdentifier = \classMethod:identifier;
                     [Maybe<[?]>] existingList = \classMethodsIndex:get \methodIdentifier:content;
                     [List<[?]>] listOfMethodsWithSameName = \existingList:isOrElse (*(e)->e) *->[List<[DainaClassMethod<[DainaExpression]>]>]{
                        [List<[?]>] newList = \[List<[DainaClassMethod<[DainaExpression]>]>]:empty;
                        \classMethodsIndex:set (\methodIdentifier:content) \[Maybe<[?]>]:as newList;
                     } -> newList;
                     \listOfMethodsWithSameName:append classMethod;
                  };
                  \.methodsPerClass:set className \[Maybe<[?]>]:as classMethodsIndex;
                  \.parentsPerClass:set className \[Maybe<[?]>]:as inheritedParentTypes;
               };
         };
      };
      @@\classes:iterate *([DainaClass] class) {
         \:checkForCircularDependancies (\class:position) class (\[List<[DainaClassIdentifier]>]:empty) (\[Index<[DainaClassIdentifier]>]:empty) visited;
      };@@
@@
      [Maybe<[?]>] asdf = \.methodsPerClass:get \[String]:as ##DainaGeneralIdentifier##;
      \asdf:isOrElse *([Index<[List<[DainaClassMethod<[DainaExpression]>]>]>] methods){
         \[Debug]:log (\[String]:as ##asdfD\n##);
         [Maybe<[?]>] methodListMaybe = \methods:get \[String]:as ##content##;
         \methodListMaybe:isOrElse *([List<[]>] ddd){
            \[Debug]:log (\[String]:as ##asdfG\n##);
            \[Debug]:log (\[String]:stringFormatOf \ddd:length);
            \[Debug]:log (\[String]:as ##\n##);
            } *{
\[Debug]:log (\[String]:as ##asdfH\n##);
         };
      } *{
         \[Debug]:log (\[String]:as ##asdfM\n##);
      };@@
      [Maybe<[List<[DainaClass]>]>] maybeClassOrder = \:orderClassesBasedOnDependancies classes;
      \maybeClassOrder:isOrElse *([List<[DainaClass]>] classOrder) {
         \classOrder:iterate *([DainaClass] class) {
            @check instance objects and put them in scope
            @check class methods and put them in scope
            @generic class types [List<[DainaGeneralIdentifier]>] genericDeclarationList

            \.classInScope:set class;
            \class:isEntryPointOrRegularClass *{
               \.instanceObjects:set \[Index<[DainaObjectDeclaration]>]:empty;
            } *([DainaClassIdentifier] classId, [List<[DainaType]>] inheritedParentTypes, [Index<[DainaObjectDeclaration]>] instanceObjects, [List<[DainaClassMethod<[DainaExpression]>]>] classMethods, [List<[DainaCompilerInjection]>] compilerInjections) {
               \.instanceObjects:set instanceObjects;

               @put these in, make sure methods fit and method include parent methodz
               @[Index<[Index<[List<[DainaClassMethod<[DainaExpression]>]>]>]>] methodsPerClass
               @  [Index<[Index<[DainaObjectDeclaration]>]>] instanceObjectsPerClass

            };



            \class:analyze ^;
         };
      } *{};

      



@@

      \classes:iterate *([DainaClass] class) {
         \class:isEntryPointOrRegularClass *([DainaDependancyStructure] dependancyStructure, [DainaExpression] entryPointMethod) {
            [Maybe<[DainaClass]>] entryPoint = \.entryPoint:get;
            \entryPoint:isOrElse 
               *([DainaClass] original){\:addError (\[Error]:duplicateEntryPointClass (\class:position) (\original:position))} 
               *{\.entryPoint:set \[Maybe<[DainaClass]>]:as class};
         } *([DainaClassIdentifier] classId, [List<[DainaType]>] inheritedParentTypes, [List<[DainaObjectDeclaration]>] instanceObjects, [List<[DainaClassMethod<[DainaExpression]>]>] classMethods, [List<[DainaCompilerInjection]>] compilerInjections) {
            [String] className = \classId:content;
            [Maybe<[?]>] existingClass = \.classIndex:get className;
            \existingClass:isOrElse
               *([DainaClass] original){\:addError (\[Error]:duplicateClassName (\class:position) (\original:position))} 
               *{\.classIndex:set className \[Maybe<[?]>]:as class};
         };
      };



   [List<[DainaClassIdentifier]>] dependancies
   [List<[DainaClassIdentifier]>] dependanciesWithDerivatives
   [List<[DainaClassIdentifier]>] reverseDependancies@@
      
      
   @duplicates check in parser

      @ dependancies, with derivatives, reverse dependancies, prevent looped structure

      @ananlyze each class individualy

